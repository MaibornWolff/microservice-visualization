{
  "name": "tadis-analyzer",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MaibornWolff/microservice-visualization.git"
  },
  "version": "2.2.2",
  "description": "generic analyzer tool for architecture discovery",
  "main": "build/lib.js",
  "types": "build/lib.d.ts",
  "files": [
    "build/"
  ],
  "license": "Apache-2.0",
  "author": "Andreas Blunk, MaibornWolff GmbH",
  "type": "module",
  "sideEffects": false,
  "scripts": {
    "build": "rm -rf build && tsc",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "ts-node -r tsconfig-paths/register src/app/default/main.ts",
    "start:dev": "nodemon",
    "start:debug": "nodemon --config nodemon-debug.json",
    "start:prod": "node build/app/default/main.js",
    "code-pattern": "ts-node -r tsconfig-paths/register src/app/code-pattern/main.ts",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\"",
    "lint-fix": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:cov": "vitest run --coverage"
  },
  "dependencies": {
    "@kubernetes/client-node": "^1.4.0",
    "@nestjs/axios": "^4.0.1",
    "@nestjs/common": "^11.1.27",
    "@nestjs/core": "^11.1.27",
    "@nestjs/platform-express": "^11.1.27",
    "axios": "^1.18.0",
    "dotenv": "^17.4.2",
    "immer": "^11.1.8",
    "joi": "^18.2.3",
    "lodash": "^4.18.1",
    "reflect-metadata": "^0.2.2",
    "rimraf": "^6.1.3",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.23",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.27",
    "@swc/core": "^1.15.43",
    "@types/express": "^5.0.6",
    "@types/lodash": "^4.17.24",
    "@types/node": "^26.0.0",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.4",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "unplugin-swc": "^1.5.9",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "multer": "^2.2.0"
  }
}
