{
  "compilerOptions": {
    "module": "ESNext",
    "target": "ES2024",
    "moduleResolution": "bundler",
    "allowJs": true,
    // TypeScript 6 turns the strict family on by default; keep it off to
    // preserve this project's previously lenient (non-strict) typing.
    "strict": false,
    "sourceMap": true,
    "outDir": "build",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "rootDirs": [
      "src"
    ],
    "lib": [
      "es2024",
      "dom",
      "dom.iterable",
      "ESNext.Disposable"
    ],
    "types": [
      "node",
      "vitest"
    ]
  },
  "exclude": [
    "node_modules",
    "**/*.js",
    "build"
  ]
}
